# Copy to .env and paste your teacher-model API key.
# Default provider is Groq (fast + free): get a key at https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional alternate provider (set TEACHER_PROVIDER="nvidia" in src/config.py to use it):
# NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
